{
  "name": "joinburn",
  "version": "0.3.0",
  "description": "Collector CLI for Burn — syncs multi-agent usage aggregates. Aggregates only: never prompts, paths, or content.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/edwardtanoto/joinburn#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edwardtanoto/joinburn.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/edwardtanoto/joinburn/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "joinburn": "dist/cli.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node20 --clean",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test src",
    "prepack": "bun run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@joinburn/shared": "file:../shared",
    "@types/bun": "^1.1.14",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
