{
  "name": "joinburn-cli",
  "private": true,
  "version": "0.2.3",
  "description": "Open-source collector and pairing CLI for Burn",
  "license": "MIT",
  "bin": {
    "joinburn": "packages/cli/dist/cli.js"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter joinburn build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test packages/cli/src",
    "check": "bun run typecheck && bun run test && bun run build",
    "prepare": "cd packages/cli && npm run build"
  },
  "engines": {
    "node": ">=20.9"
  },
  "packageManager": "bun@1.3.5"
}
